{
  "/api": {
    "target": "http://forge-api:8080",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "warn",
    "headers": {
      "X-Forwarded-Host": "localhost:4200",
      "X-Forwarded-Proto": "http"
    }
  },
  "/hubs": {
    "target": "http://forge-api:8080",
    "secure": false,
    "changeOrigin": true,
    "ws": true,
    "logLevel": "warn"
  },
  "/docuseal": {
    "target": "http://forge-signing:3000",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "warn"
  }
}
