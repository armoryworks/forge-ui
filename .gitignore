# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# i18n trap — see scripts/lint-i18n.mjs and CLAUDE.md.
# i18n files live at public/assets/i18n/ (the bundled location per
# angular.json). src/assets/i18n/ is a vestigial path from before the
# Angular CLI public/ migration. Editing it produces silent runtime
# failures (raw "foo.bar" keys in the UI). Ignored so an IDE auto-save
# or scaffolder mistake can never sneak it back into the repo.
/src/assets/i18n/

# Node
/node_modules
npm-debug.log
yarn-error.log

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# Miscellaneous
/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# Playwright
/e2e/test-results/
/e2e/playwright-report/
/e2e/screenshots/
/e2e/uat-results/
/e2e/stress/last-run.log
/test-results/

# Generated at build time
/public/assets/version.json

# System files
.DS_Store
Thumbs.db

# Analysis/audit probe scratch at repo ROOT (regenerable; deliverables live in
# forge-analysis). Configs are .js/.ts, so no legit root .mjs/.cjs to keep.
/*.mjs
/*.cjs
e2e/playwright.local.config.ts
