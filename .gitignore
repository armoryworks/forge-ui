# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# i18n trap — see scripts/lint-i18n.mjs and CLAUDE.md.
# i18n files live at public/assets/i18n/ (the bundled location per
# angular.json). src/assets/i18n/ is a vestigial path from before the
# Angular CLI public/ migration. Editing it produces silent runtime
# failures (raw "foo.bar" keys in the UI). Ignored so an IDE auto-save
# or scaffolder mistake can never sneak it back into the repo.
/src/assets/i18n/

# Node
/node_modules
npm-debug.log
yarn-error.log

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# Miscellaneous
/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# Playwright
/e2e/test-results/
/e2e/playwright-report/
/e2e/screenshots/
/e2e/uat-results/
/e2e/stress/last-run.log
/test-results/

# Generated at build time
/public/assets/version.json

# Sample screenshots — regenerable from e2e/tests/sample-screenshots.spec.ts.
# Not committed because (a) the f3-scan cardboard render uses Math.random()
# so every run diffs, and (b) kiosk frames bake the wall-clock time into
# the Shop Floor header. Run the spec on demand; downstream consumers
# (marketing site, docs site) pull from a release artifact, not git.
/public/sample-screenshots/

# System files
.DS_Store
Thumbs.db
